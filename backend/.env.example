# Server
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Database (SQLite file path, relative to backend working dir)
DATABASE_PATH=../data/app.sqlite

# Demo seed password shared by all seeded accounts
SEED_PASSWORD=password123

# Path to the built frontend (served as static SPA). Leave empty in dev.
# In the Docker image this is set to the copied frontend build directory.
FRONTEND_DIST=
